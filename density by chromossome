#!/usr/bin/env python3

import pandas as pd

# -----------------------------
# arquivos
# -----------------------------
bed_file = "lncRNAs_with_parental.bed"
sizes_file = "SofficinarumxspontaneumR570_771_v2.0.softmasked_sequences_sizes.tsv"

# -----------------------------
# lê tamanhos cromossômicos
# -----------------------------
sizes = pd.read_csv(sizes_file, sep="\t")

sizes.columns = ["chrom", "length"]

# remove possível header residual
sizes = sizes[sizes["chrom"] != "Sequence"]

# garante tipo numérico
sizes["length"] = pd.to_numeric(sizes["length"])

# -----------------------------
# lê BED
# -----------------------------
bed = pd.read_csv(
    bed_file,
    sep="\t",
    header=None,
    usecols=[0, 1, 2, 3],
    names=["chrom", "start", "end", "lncRNA"]
)

# =====================================================
# 1. TRANSCRITOS ÚNICOS POR CROMOSSOMO
# =====================================================

unique_counts = (
    bed.groupby("chrom")["lncRNA"]
    .nunique()
    .reset_index(name="n_unique_lncRNAs")
)

df_unique = sizes.merge(unique_counts, on="chrom", how="left")

df_unique["n_unique_lncRNAs"] = (
    df_unique["n_unique_lncRNAs"]
    .fillna(0)
    .astype(int)
)

df_unique["length_mb"] = df_unique["length"] / 1_000_000

df_unique["density_unique_per_mb"] = (
    df_unique["n_unique_lncRNAs"] /
    df_unique["length_mb"]
)

df_unique = df_unique.sort_values(
    "density_unique_per_mb",
    ascending=False
)

df_unique.to_csv(
    "lncRNA_density_unique.tsv",
    sep="\t",
    index=False
)

# =====================================================
# 2. TODAS AS OCORRÊNCIAS POR CROMOSSOMO
# =====================================================

total_counts = (
    bed.groupby("chrom")
    .size()
    .reset_index(name="n_total_occurrences")
)

df_total = sizes.merge(total_counts, on="chrom", how="left")

df_total["n_total_occurrences"] = (
    df_total["n_total_occurrences"]
    .fillna(0)
    .astype(int)
)

df_total["length_mb"] = df_total["length"] / 1_000_000

df_total["density_total_per_mb"] = (
    df_total["n_total_occurrences"] /
    df_total["length_mb"]
)

df_total = df_total.sort_values(
    "density_total_per_mb",
    ascending=False
)

df_total.to_csv(
    "lncRNA_density_total.tsv",
    sep="\t",
    index=False
)

# -----------------------------
# resumo
# -----------------------------
print("\nArquivo 1:")
print("lncRNA_density_unique.tsv")

print("\nArquivo 2:")
print("lncRNA_density_total.tsv")
